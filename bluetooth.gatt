// reference
// https://github.com/bluekitchen/btstack/blob/master/example/gatt_streamer_server.gatt


// name
PRIMARY_SERVICE, GAP_SERVICE
CHARACTERISTIC, GAP_DEVICE_NAME, READ, "RC Car"

PRIMARY_SERVICE, GATT_SERVICE
CHARACTERISTIC, GATT_DATABASE_HASH, READ,


PRIMARY_SERVICE, F206765C-58A6-467B-8D8B-FCB9895E8FD0

// phone -> car
// steering + throttle
CHARACTERISTIC, F206765C-58A6-467B-8D8B-FCB9895E8FD1, WRITE_WITHOUT_RESPONSE | DYNAMIC

// car -> phone
// responses back
CHARACTERISTIC, F206765C-58A6-467B-8D8B-FCB9895E8FD2, NOTIFY | DYNAMIC
